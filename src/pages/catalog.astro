---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');

// Group products by category
const categories = [...new Set(products.map(p => p.data.category))];
---

<Layout title="Каталог">
    <div class="bg-slate-50 py-12 border-b border-slate-200">
        <div class="max-w-screen-2xl mx-auto px-8">
            <h1 class="text-4xl md:text-5xl font-black font-headline text-slate-900 mb-4">Каталог продукции</h1>
            <p class="text-lg text-slate-600 max-w-2xl">Полный ассортимент газобаллонного оборудования DIGITRONIC.</p>
        </div>
    </div>

    <div class="max-w-screen-2xl mx-auto px-8 py-12 flex flex-col md:flex-row gap-8">
        <!-- Sidebar -->
        <aside class="w-full md:w-64 shrink-0">
            <div class="bg-white rounded-xl border border-slate-200 p-6 sticky top-24">
                <h3 class="font-bold font-headline text-lg mb-4 text-slate-900">Категории</h3>
                <ul class="space-y-2">
                    <li><a href="#" class="text-blue-600 font-medium block py-1">Все товары</a></li>
                    {categories.map(cat => (
                        <li><a href={`#cat-${cat}`} class="text-slate-600 hover:text-blue-600 transition-colors block py-1">{cat}</a></li>
                    ))}
                </ul>
            </div>
        </aside>

        <!-- Product Grid -->
        <div class="flex-1">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {products.map(product => (
                    <a href={`/catalog/${product.id}`} class="group bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-xl transition-all hover:-translate-y-1 block">
                        <div class="aspect-square bg-slate-100 relative overflow-hidden">
                            {product.data.image ? (
                                <img src={product.data.image} alt={product.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
                            ) : (
                                <div class="w-full h-full flex items-center justify-center text-slate-400">Нет фото</div>
                            )}
                            <div class="absolute top-4 left-4 bg-white/90 backdrop-blur text-xs font-bold px-3 py-1 rounded-full text-slate-700">
                                {product.data.category}
                            </div>
                        </div>
                        <div class="p-6">
                            <h3 class="font-bold font-headline text-lg text-slate-900 mb-2 group-hover:text-blue-600 transition-colors">{product.data.title}</h3>
                            <p class="text-slate-500 text-sm mb-4 line-clamp-2">Высококачественное оборудование от производителя.</p>
                            <div class="flex items-center justify-between mt-auto">
                                <span class="font-bold text-lg text-slate-900">{product.data.price || 'По запросу'}</span>
                                <span class="material-symbols-outlined text-blue-600 opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all">arrow_forward</span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </div>
</Layout>
