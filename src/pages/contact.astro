---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Контакты">
    <div class="bg-slate-50 py-16 border-b border-slate-200">
        <div class="max-w-screen-2xl mx-auto px-8 text-center">
            <h1 class="text-4xl md:text-5xl font-black font-headline text-slate-900 mb-4">Свяжитесь с нами</h1>
            <p class="text-lg text-slate-600 max-w-2xl mx-auto">Мы всегда готовы ответить на ваши вопросы и обсудить сотрудничество.</p>
        </div>
    </div>

    <div class="max-w-screen-2xl mx-auto px-8 py-16 grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
            <h2 class="text-3xl font-bold font-headline mb-8 text-slate-900">Контактная информация</h2>
            <div class="space-y-6">
                <div class="flex items-start">
                    <span class="material-symbols-outlined text-blue-600 mt-1 mr-4">location_on</span>
                    <div>
                        <h4 class="font-bold text-slate-900">Адрес</h4>
                        <p class="text-slate-600">г. Москва, ул. Примерная, д. 1, офис 101</p>
                    </div>
                </div>
                <div class="flex items-start">
                    <span class="material-symbols-outlined text-blue-600 mt-1 mr-4">phone</span>
                    <div>
                        <h4 class="font-bold text-slate-900">Телефон</h4>
                        <p class="text-slate-600">8 (800) 555-35-35</p>
                    </div>
                </div>
                <div class="flex items-start">
                    <span class="material-symbols-outlined text-blue-600 mt-1 mr-4">mail</span>
                    <div>
                        <h4 class="font-bold text-slate-900">Email</h4>
                        <p class="text-slate-600">info@digitronicgas.ru</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-white p-8 rounded-2xl border border-slate-200 shadow-sm">
            <h3 class="text-2xl font-bold font-headline mb-6 text-slate-900">Отправить сообщение</h3>
            <form class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Имя</label>
                    <input type="text" class="w-full border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
                    <input type="email" class="w-full border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Сообщение</label>
                    <textarea rows="4" class="w-full border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"></textarea>
                </div>
                <button type="button" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-4 rounded-lg transition-colors">
                    Отправить
                </button>
            </form>
        </div>
    </div>
</Layout>
