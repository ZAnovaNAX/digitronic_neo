---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ru" class="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title} | DIGITRONIC</title>
		<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
	</head>
	<body class="bg-background text-on-background font-body antialiased">
        <nav class="bg-surface-variant/70 backdrop-blur-xl docked full-width top-0 sticky z-50 no-border bg-slate-100/50 dark:bg-slate-800/50 flat no shadows">
            <div class="flex justify-between items-center w-full px-8 py-4 max-w-screen-2xl mx-auto">
                <div class="flex items-center">
                    <img alt="DIGITRONIC Logo" class="h-8 w-auto object-contain" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAfIPoWKC3NO6X1VmqUVuHeNVSL9Kz34J1FnSVWjOmlOtoHvAmAyjeXCDqo6BXl0pejsMUkhzWvQKQwpiF6GyRhFmqo_xcyxad1sMBdn0-ORvR4G8SMDALn116F2gkqBzTS32036IRnDZnfFbzTpgrneEU3sJ60evLim7C4R9RWMIqp8HbBRnOLVm-G-1TvRIBqxLt5qL5T6SjXXazbaUNBgmkGWHbrvJ8uRSgitQH0gk5vmqpgaPOxe-hJnBN8IfGE-ED4Cbpllg"/>
                </div>
                <div class="hidden md:flex space-x-8 items-center">
                    <a class="text-slate-600 dark:text-slate-400 font-medium font-headline hover:text-blue-600 dark:hover:text-blue-300 transition-colors" href="/">Главная</a>
                    <a class="text-slate-600 dark:text-slate-400 font-medium font-headline hover:text-blue-600 dark:hover:text-blue-300 transition-colors" href="/catalog">Каталог</a>
                    <a class="text-slate-600 dark:text-slate-400 font-medium font-headline hover:text-blue-600 dark:hover:text-blue-300 transition-colors" href="/software">ПО и Документация</a>
                    <a class="text-slate-600 dark:text-slate-400 font-medium font-headline hover:text-blue-600 dark:hover:text-blue-300 transition-colors" href="/about">О компании</a>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="relative hidden lg:block">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline-variant">search</span>
                        <input class="pl-10 pr-4 py-2 rounded-full bg-surface-container-highest border-none focus:ring-0 focus:bg-surface-container-lowest focus:border-b-2 focus:border-b-primary-container text-sm w-64 transition-all" placeholder="Search products..." type="text"/>
                    </div>
                    <a href="/contact" class="bg-gradient-to-br from-blue-600 to-blue-400 text-white rounded-full px-6 py-2 font-bold font-headline hover:opacity-90 transition-opacity">
                        Стать партнером
                    </a>
                </div>
            </div>
        </nav>

		<main>
			<slot />
		</main>

        <footer class="bg-slate-900 text-white py-12 mt-auto">
            <div class="max-w-screen-2xl mx-auto px-8 grid grid-cols-1 md:grid-cols-4 gap-8">
                <div>
                    <img alt="DIGITRONIC Logo" class="h-8 w-auto object-contain brightness-0 invert mb-6" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAfIPoWKC3NO6X1VmqUVuHeNVSL9Kz34J1FnSVWjOmlOtoHvAmAyjeXCDqo6BXl0pejsMUkhzWvQKQwpiF6GyRhFmqo_xcyxad1sMBdn0-ORvR4G8SMDALn116F2gkqBzTS32036IRnDZnfFbzTpgrneEU3sJ60evLim7C4R9RWMIqp8HbBRnOLVm-G-1TvRIBqxLt5qL5T6SjXXazbaUNBgmkGWHbrvJ8uRSgitQH0gk5vmqpgaPOxe-hJnBN8IfGE-ED4Cbpllg"/>
                    <p class="text-slate-400 text-sm">Ведущий производитель газобаллонного оборудования высокого качества.</p>
                </div>
                <div>
                    <h4 class="font-bold mb-4 font-headline text-lg">Навигация</h4>
                    <ul class="space-y-2 text-slate-400 text-sm">
                        <li><a href="/" class="hover:text-white transition-colors">Главная</a></li>
                        <li><a href="/catalog" class="hover:text-white transition-colors">Каталог</a></li>
                        <li><a href="/software" class="hover:text-white transition-colors">ПО</a></li>
                        <li><a href="/about" class="hover:text-white transition-colors">О нас</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold mb-4 font-headline text-lg">Контакты</h4>
                    <ul class="space-y-2 text-slate-400 text-sm">
                        <li>info@digitronicgas.ru</li>
                        <li>8 (800) 555-35-35</li>
                        <li>Москва, ул. Примерная, 1</li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold mb-4 font-headline text-lg">Подписка</h4>
                    <p class="text-slate-400 text-sm mb-4">Получайте новости о наших продуктах</p>
                    <div class="flex">
                        <input type="email" placeholder="Email" class="bg-slate-800 border-none text-white px-4 py-2 rounded-l-md w-full focus:ring-0"/>
                        <button class="bg-blue-600 px-4 py-2 rounded-r-md hover:bg-blue-500 transition-colors">
                            <span class="material-symbols-outlined text-sm">send</span>
                        </button>
                    </div>
                </div>
            </div>
            <div class="max-w-screen-2xl mx-auto px-8 mt-12 pt-8 border-t border-slate-800 text-slate-500 text-xs text-center">
                © 2024 DIGITRONIC. Все права защищены.
            </div>
        </footer>
	</body>
</html>
